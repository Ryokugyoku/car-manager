{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron Main Debug",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "runtimeArgs": ["."],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "preLaunchTask": "electron:compile",
      "outFiles": ["${workspaceFolder}/dist-electron/**/*.js"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/dist-electron/**/*.js",
        "!${workspaceFolder}/.angular/**",
        "!**/node_modules/**"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Electron Main Attach",
      "type": "node",
      "request": "attach",
      "port": 5858,
      "address": "localhost",
      "restart": true
    },
    {
      "name": "Electron Dev (Auto-reload)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "runtimeArgs": ["--inspect=5858", "."],
      "cwd": "${workspaceFolder}",
      "env": {
        "NODE_ENV": "development"
      },
      "preLaunchTask": "electron:dev-watch",
      "outFiles": ["${workspaceFolder}/dist-electron/**/*.js"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/dist-electron/**/*.js",
        "!${workspaceFolder}/.angular/**",
        "!**/node_modules/**"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "ng serve",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "build-and-serve",
      "url": "http://localhost:4200/"
    },
    {
      "name": "ng test",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "build-and-test",
      "url": "http://localhost:9876/debug.html"
    }
  ]
}
