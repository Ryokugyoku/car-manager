{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "npm",
      "script": "build",
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "build-and-serve",
      "dependsOn": ["build", "npm: start"],
      "group": {
        "kind": "none"
      }
    },
    {
      "label": "build-and-test",
      "dependsOn": ["build", "npm: test"],
      "group": {
        "kind": "none"
      }
    },
    {
      "label": "electron:compile",
      "type": "npm",
      "script": "electron:compile",
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc"
      },
      "group": {
        "kind": "build"
      }
    },
    {
      "label": "npm: electron:compile:watch",
      "type": "npm",
      "script": "electron:compile:watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Starting compilation in watch mode"
          },
          "endsPattern": {
            "regexp": "Found \\d+ errors?\\. Watching for file changes"
          }
        }
      }
    },
    {
      "label": "npm: start:electron",
      "type": "npm",
      "script": "start:electron",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "electron:dev-watch",
      "dependsOn": ["npm: start:electron", "npm: electron:compile:watch"],
      "problemMatcher": [],
      "group": {
        "kind": "none"
      }
    }
  ]
}
